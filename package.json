{
  "name": "crisis-monitor",
  "version": "0.1.0",
  "description": "Crisis Monitor - Automated macro-economic tracking system",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "test:unit": "jest --testPathPattern=tests/unit --forceExit",
    "test:functional": "jest --testPathPattern=tests/functional --forceExit",
    "test:smoke": "jest --testPathPattern=tests/smoke --forceExit"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
